# ============================================================================
# GlideKV TensorFlow Serving 环境配置
# ============================================================================
# 
# 配置文件: glidekv.env
# 用途: TensorFlow Serving 启动时的环境变量配置
# 版本: r2.15
# 
# 使用方式:
#   source glidekv.env
#   或
#   export $(cat glidekv.env | grep -v '^#' | xargs)
# ============================================================================

# ============================================================================
# 🎯 核心配置
# ============================================================================

# 应用名称和版本
GLIDEKV_APP_NAME=glidekv
GLIDEKV_VERSION=1.0.0
GLIDEKV_ENV=production

# ============================================================================
# 📊 Prometheus 指标配置
# ============================================================================

# 全局指标开关
GLIDEKV_METRICS_ENABLED=1

# 指标采样率 (0.0-1.0)
# 1.0 = 100% 采样，0.1 = 10% 采样
GLIDEKV_METRICS_SAMPLING_RATE=1.0

# ============================================================================
# 🔧 指标开关配置
# ============================================================================

# 操作计数指标
GLIDEKV_METRIC_LOOKUP_OPS_TOTAL=1
GLIDEKV_METRIC_LOOKUP_FAILURES_TOTAL=1
GLIDEKV_METRIC_CONNECTION_FAILURES_TOTAL=1

# 吞吐量指标
GLIDEKV_METRIC_TOTAL_KEYS=1
GLIDEKV_METRIC_FAILED_KEYS=1

# 延迟指标 - Value Counter方式
GLIDEKV_METRIC_LOOKUP_LATENCY_MS=1
GLIDEKV_METRIC_TOTAL_LATENCY_MS=1

# 延迟指标 - Histogram方式
GLIDEKV_METRIC_LOOKUP_LATENCY_HISTOGRAM=1
GLIDEKV_METRIC_TOTAL_LATENCY_HISTOGRAM=1

# 系统监控指标
GLIDEKV_METRIC_SYSTEM_CPU_USAGE_PERCENT=1
GLIDEKV_METRIC_SYSTEM_MEMORY_USAGE_PERCENT=1
GLIDEKV_METRIC_SYSTEM_MEMORY_AVAILABLE_GB=1

# ============================================================================
# 🗄️ Aerospike 数据库配置
# ============================================================================

# 服务器连接配置
AEROSPIKE_HOST=localhost
AEROSPIKE_PORT=3000

# 数据存储配置
AEROSPIKE_NAMESPACE=test
AEROSPIKE_SET=glidekv_data
AEROSPIKE_FIELD=features

# 连接池配置
AEROSPIKE_CONNECTION_POOL_SIZE=10
AEROSPIKE_CONNECTION_TIMEOUT_MS=1000
AEROSPIKE_OPERATION_TIMEOUT_MS=5000

# ============================================================================
# 🤖 TensorFlow Serving 配置
# ============================================================================

# 服务端口配置
TENSORFLOW_SERVING_PORT=8500
TENSORFLOW_SERVING_REST_PORT=8501
TENSORFLOW_SERVING_GRPC_PORT=8500

# 模型配置
TENSORFLOW_SERVING_MODEL_NAME=glidekv_model
TENSORFLOW_SERVING_MODEL_BASE_PATH=/data/models

# 批处理配置
TENSORFLOW_SERVING_ENABLE_BATCHING=true
TENSORFLOW_SERVING_MAX_BATCH_SIZE=1000
TENSORFLOW_SERVING_BATCH_TIMEOUT_MICROS=1000
TENSORFLOW_SERVING_MAX_ENQUEUED_BATCHES=100

# 性能配置
TENSORFLOW_SERVING_NUM_LOAD_THREADS=4
TENSORFLOW_SERVING_NUM_UNLOAD_THREADS=4
TENSORFLOW_SERVING_MAX_NUM_LOAD_RETRIES=5

# 日志配置
TENSORFLOW_SERVING_LOG_LEVEL=INFO
TENSORFLOW_SERVING_LOG_VERBOSITY=0

# ============================================================================
# 🔒 安全配置
# ============================================================================

# 指标访问控制
GLIDEKV_METRICS_ALLOW_ORIGINS=127.0.0.1,localhost
GLIDEKV_METRICS_REQUIRE_AUTH=false

# 服务访问控制
TENSORFLOW_SERVING_ALLOW_ORIGINS=*
TENSORFLOW_SERVING_CORS_ALLOWED_ORIGINS=*

# ============================================================================
# 📝 日志配置
# ============================================================================

# 日志级别
GLIDEKV_LOG_LEVEL=INFO
GLIDEKV_LOG_FORMAT=json

# 日志输出
GLIDEKV_LOG_TO_FILE=true
GLIDEKV_LOG_FILE_PATH=/var/log/glidekv/glidekv.log
GLIDEKV_LOG_MAX_SIZE=100MB
GLIDEKV_LOG_MAX_FILES=10

# ============================================================================
# ⚡ 性能调优配置
# ============================================================================

# 内存配置
GLIDEKV_MAX_MEMORY_USAGE_GB=8
GLIDEKV_CACHE_SIZE_MB=1024

# 线程配置
GLIDEKV_WORKER_THREADS=4
GLIDEKV_IO_THREADS=2

# 超时配置
GLIDEKV_REQUEST_TIMEOUT_MS=30000
GLIDEKV_CONNECTION_TIMEOUT_MS=5000

# ============================================================================
# 🔍 调试配置
# ============================================================================

# 调试模式
GLIDEKV_DEBUG_MODE=false
GLIDEKV_PROFILING_ENABLED=false

# 性能分析
GLIDEKV_PERF_PROFILING=false
GLIDEKV_PERF_SAMPLING_RATE=0.01

# ============================================================================
# 📋 配置验证
# ============================================================================

# 配置验证开关
GLIDEKV_CONFIG_VALIDATION=true
GLIDEKV_CONFIG_STRICT_MODE=false 